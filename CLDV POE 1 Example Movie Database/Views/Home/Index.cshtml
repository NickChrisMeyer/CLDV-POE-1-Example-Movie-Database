@{
    ViewData["Title"] = "Dashboard";
}

<div class="p-4 p-md-5 mb-4 rounded-3 bg-light border shadow-sm">
    <h1 class="display-6 fw-semibold">Movie Booking Dashboard</h1>
    <p class="lead mb-4">Manage movies, cinemas, and screening schedules with overlap validation.</p>
    <div class="d-flex gap-2 flex-wrap">
        <a asp-controller="Movies" asp-action="Index" class="btn btn-primary">Manage Movies</a>
        <a asp-controller="Cinemas" asp-action="Index" class="btn btn-outline-primary">Manage Cinemas</a>
        <a asp-controller="Screenings" asp-action="Index" class="btn btn-outline-dark">View Screenings</a>
    </div>
</div>
