@model IEnumerable<CLDV_POE_1_Example_Movie_Database.Models.Screening>
@{
    ViewData["Title"] = "Screenings";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Screenings</h1>
    <a asp-action="Create" class="btn btn-primary">Schedule Screening</a>
</div>

<div class="table-responsive shadow-sm rounded">
    <table class="table table-striped table-hover mb-0">
        <thead class="table-dark">
            <tr>
                <th>Movie</th>
                <th>Cinema</th>
                <th>Start</th>
                <th>End</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Movie?.Title</td>
                <td>@item.Cinema?.Name</td>
                <td>@item.StartTime.ToString("yyyy-MM-dd HH:mm")</td>
                <td>@item.EndTime.ToString("yyyy-MM-dd HH:mm")</td>
                <td class="text-end">
                    <a asp-action="Details" asp-route-id="@item.ScreeningId" class="btn btn-sm btn-outline-secondary">Details</a>
                    <a asp-action="Edit" asp-route-id="@item.ScreeningId" class="btn btn-sm btn-outline-primary">Edit</a>
                    <a asp-action="Delete" asp-route-id="@item.ScreeningId" class="btn btn-sm btn-outline-danger">Delete</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
