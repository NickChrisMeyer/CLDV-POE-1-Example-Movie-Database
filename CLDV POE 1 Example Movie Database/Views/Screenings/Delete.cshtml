@model CLDV_POE_1_Example_Movie_Database.Models.Screening
@{
    ViewData["Title"] = "Delete Screening";
}

<h1 class="mb-3 text-danger">Delete Screening</h1>

<div class="alert alert-warning">Are you sure you want to delete this screening?</div>

<div class="card shadow-sm">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Movie</dt>
            <dd class="col-sm-9">@Model.Movie?.Title</dd>
            <dt class="col-sm-3">Cinema</dt>
            <dd class="col-sm-9">@Model.Cinema?.Name</dd>
            <dt class="col-sm-3">Start</dt>
            <dd class="col-sm-9">@Model.StartTime.ToString("yyyy-MM-dd HH:mm")</dd>
            <dt class="col-sm-3">End</dt>
            <dd class="col-sm-9">@Model.EndTime.ToString("yyyy-MM-dd HH:mm")</dd>
        </dl>
    </div>
</div>

<form asp-action="Delete" class="mt-3">
    <input type="hidden" asp-for="ScreeningId" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
</form>
