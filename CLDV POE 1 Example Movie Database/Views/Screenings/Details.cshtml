@model CLDV_POE_1_Example_Movie_Database.Models.Screening
@{
    ViewData["Title"] = "Screening Details";
}

<h1 class="mb-3">Screening Details</h1>

<div class="card shadow-sm">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Movie</dt>
            <dd class="col-sm-9">@Model.Movie?.Title</dd>

            <dt class="col-sm-3">Cinema</dt>
            <dd class="col-sm-9">@Model.Cinema?.Name</dd>

            <dt class="col-sm-3">Start Time</dt>
            <dd class="col-sm-9">@Model.StartTime.ToString("yyyy-MM-dd HH:mm")</dd>

            <dt class="col-sm-3">End Time</dt>
            <dd class="col-sm-9">@Model.EndTime.ToString("yyyy-MM-dd HH:mm")</dd>
        </dl>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.ScreeningId" class="btn btn-primary">Edit</a>
    <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
</div>
