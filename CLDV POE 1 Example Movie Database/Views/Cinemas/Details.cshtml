@model CLDV_POE_1_Example_Movie_Database.Models.Cinema
@{
    ViewData["Title"] = "Cinema Details";
}

<h1 class="mb-3">Cinema Details</h1>

<div class="card shadow-sm">
    <div class="card-body row g-3">
        <div class="col-md-4">
            <img src="@Model.ImageUrl" alt="@Model.Name" class="img-fluid rounded" />
        </div>
        <div class="col-md-8">
            <dl class="row mb-0">
                <dt class="col-sm-3">Name</dt>
                <dd class="col-sm-9">@Model.Name</dd>

                <dt class="col-sm-3">City</dt>
                <dd class="col-sm-9">@Model.City</dd>

                <dt class="col-sm-3">Seats</dt>
                <dd class="col-sm-9">@Model.Seats</dd>
            </dl>
        </div>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.CinemaId" class="btn btn-primary">Edit</a>
    <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
</div>
