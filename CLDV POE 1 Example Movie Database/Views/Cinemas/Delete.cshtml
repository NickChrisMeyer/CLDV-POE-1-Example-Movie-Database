@model CLDV_POE_1_Example_Movie_Database.Models.Cinema
@{
    ViewData["Title"] = "Delete Cinema";
}

<h1 class="mb-3 text-danger">Delete Cinema</h1>

<div class="alert alert-warning">Are you sure you want to delete this cinema?</div>
<div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

<div class="card shadow-sm">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Name</dt>
            <dd class="col-sm-9">@Model.Name</dd>
            <dt class="col-sm-3">City</dt>
            <dd class="col-sm-9">@Model.City</dd>
            <dt class="col-sm-3">Seats</dt>
            <dd class="col-sm-9">@Model.Seats</dd>
        </dl>
    </div>
</div>

<form asp-action="Delete" class="mt-3">
    <input type="hidden" asp-for="CinemaId" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
</form>
