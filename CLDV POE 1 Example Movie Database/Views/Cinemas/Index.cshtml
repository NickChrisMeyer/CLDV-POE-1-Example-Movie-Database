@model IEnumerable<CLDV_POE_1_Example_Movie_Database.Models.Cinema>
@{
    ViewData["Title"] = "Cinemas";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Cinemas</h1>
    <a asp-action="Create" class="btn btn-primary">Add Cinema</a>
</div>

<div class="table-responsive shadow-sm rounded">
    <table class="table table-striped table-hover mb-0">
        <thead class="table-dark">
            <tr>
                <th>@Html.DisplayNameFor(model => model.Name)</th>
                <th>@Html.DisplayNameFor(model => model.City)</th>
                <th>@Html.DisplayNameFor(model => model.Seats)</th>
                <th>Image</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.City</td>
                <td>@item.Seats</td>
                <td><img src="@item.ImageUrl" alt="@item.Name" class="rounded" style="width:84px;height:48px;object-fit:cover;" /></td>
                <td class="text-end">
                    <a asp-action="Details" asp-route-id="@item.CinemaId" class="btn btn-sm btn-outline-secondary">Details</a>
                    <a asp-action="Edit" asp-route-id="@item.CinemaId" class="btn btn-sm btn-outline-primary">Edit</a>
                    <a asp-action="Delete" asp-route-id="@item.CinemaId" class="btn btn-sm btn-outline-danger">Delete</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
