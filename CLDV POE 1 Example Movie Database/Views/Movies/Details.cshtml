@model CLDV_POE_1_Example_Movie_Database.Models.Movie
@{
    ViewData["Title"] = "Movie Details";
}

<h1 class="mb-3">Movie Details</h1>

<div class="card shadow-sm">
    <div class="card-body row g-3">
        <div class="col-md-3">
            <img src="@Model.PosterUrl" alt="@Model.Title" class="img-fluid rounded" />
        </div>
        <div class="col-md-9">
            <dl class="row mb-0">
                <dt class="col-sm-3">Title</dt>
                <dd class="col-sm-9">@Model.Title</dd>

                <dt class="col-sm-3">Genre</dt>
                <dd class="col-sm-9">@Model.Genre</dd>

                <dt class="col-sm-3">Release Date</dt>
                <dd class="col-sm-9">@Model.ReleaseDate.ToString("yyyy-MM-dd")</dd>
            </dl>
        </div>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.MovieId" class="btn btn-primary">Edit</a>
    <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
</div>
